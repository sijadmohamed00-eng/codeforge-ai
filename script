function formatProse(text, isStreaming) {
let t = text
.replace(/**(.*?)**/g, ‘<strong>$1</strong>’)
.replace(/*(.*?)*/g, ‘<em>$1</em>’)
.replace(/`([^`]+)`/g, `<code style="background:var(--surface3);padding:1px 6px;border-radius:4px;font-family:var(--font-mono);font-size:13px">$1</code>`)
.replace(/\n\n/g, ‘</p><p>’)
.replace(/\n/g, ‘<br>’);
t = ‘<p>’ + t + ‘</p>’;
if (isStreaming) t += ‘<span class="stream-cursor"></span>’;
return t;
}

