// ───────────────────────── FILE PARSER ───────────────────────────
function parseFiles(text) {
const files = [];
// نمط: `[ext:filename] ... `
const pattern = /`([a-zA-Z0-9+#]*):?([^\n`]*)\n([\s\S]*?)`/g;
let match;

while ((match = pattern.exec(text)) !== null) {
const lang = match[1].trim() || ‘text’;
const name = match[2].trim() || `file_${files.length + 1}.${lang}`;
const code = match[3];
if (code.trim()) {
files.push({ lang, name: name || `${lang}_${files.length + 1}`, code });
}
}

// إذا لم يُوجد نمط خاص، ابحث عن كتل الكود العادية
if (files.length === 0) {
const simplePattern = /`([a-zA-Z0-9+#]*)\n([\s\S]*?)`/g;
let i = 0;
while ((match = simplePattern.exec(text)) !== null) {
const lang = match[1].trim() || ‘text’;
const code = match[2];
if (code.trim()) {
files.push({ lang, name: generateFileName(lang, i), code });
i++;
}
}
}

return files;
}

function generateFileName(lang, idx) {
const map = {
html: `index${idx ? idx : ''}.html`,
css: `style${idx ? idx : ''}.css`,
js: `script${idx ? idx : ''}.js`,
javascript: `script${idx ? idx : ''}.js`,
python: `main${idx ? idx : ''}.py`,
php: `index${idx ? idx : ''}.php`,
typescript: `app${idx ? idx : ''}.ts`,
json: `config${idx ? idx : ''}.json`,
sql: `database${idx ? idx : ''}.sql`,
bash: `run${idx ? idx : ''}.sh`,
dart: `main${idx ? idx : ''}.dart`,
md: `README${idx ? idx : ''}.md`,
};
return map[lang.toLowerCase()] || `file${idx}.${lang}`;
}

function detectLang(name) {
const ext = name.split(’.’).pop().toLowerCase();
const map = { html: ‘html’, css: ‘css’, js: ‘javascript’, ts: ‘typescript’, py: ‘python’, php: ‘php’, json: ‘json’, sql: ‘sql’, md: ‘markdown’ };
return map[ext] || ‘text’;
}

function getFileIcon(name) {
const ext = name.split(’.’).pop().toLowerCase();
const icons = { html: ‘🌐’, css: ‘🎨’, js: ‘⚡’, ts: ‘💙’, py: ‘🐍’, php: ‘🐘’, json: ‘📋’, sql: ‘🗄️’, md: ‘📝’, sh: ‘🖥️’, dart: ‘🎯’ };
return icons[ext] || ‘📄’;
}

function extractSection(text, header) {
const idx = text.indexOf(header);
if (idx === -1) return ‘’;
const after = text.slice(idx + header.length).trim();
const end = after.search(/\n##\s/);
return (end === -1 ? after : after.slice(0, end)).replace(/`[\s\S]*?`/g, ‘’).trim();
}

