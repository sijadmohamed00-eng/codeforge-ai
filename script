function buildCodeBlock(lang, filename, rawCode) {
const tpl    = $(‘codeBlockTpl’).content.cloneNode(true);
const block  = tpl.querySelector(’.code-block’);
const badge  = tpl.querySelector(’.code-lang-badge’);
const fnEl   = tpl.querySelector(’.code-filename’);
const codeEl = tpl.querySelector(‘code’);
const copyBtn= tpl.querySelector(’.copy-btn’);
const dlBtn  = tpl.querySelector(’.dl-btn’);

badge.textContent     = lang.toUpperCase();
fnEl.textContent      = filename;
codeEl.innerHTML      = highlight(rawCode, lang);

copyBtn.addEventListener(‘click’, () => {
navigator.clipboard.writeText(rawCode).then(() => {
copyBtn.textContent = ‘✅ تم’;
copyBtn.classList.add(‘copied’);
setTimeout(() => { copyBtn.textContent = ‘📋 نسخ’; copyBtn.classList.remove(‘copied’); }, 2000);
}).catch(() => {
// fallback
const ta = document.createElement(‘textarea’);
ta.value = rawCode; ta.style.position = ‘fixed’; ta.style.opacity = ‘0’;
document.body.appendChild(ta); ta.select();
document.execCommand(‘copy’);
document.body.removeChild(ta);
copyBtn.textContent = ‘✅ تم’; copyBtn.classList.add(‘copied’);
setTimeout(() => { copyBtn.textContent = ‘📋 نسخ’; copyBtn.classList.remove(‘copied’); }, 2000);
});
});

dlBtn.addEventListener(‘click’, () => {
const blob = new Blob([rawCode], { type: ‘text/plain;charset=utf-8’ });
const url  = URL.createObjectURL(blob);
const a    = document.createElement(‘a’);
a.href = url; a.download = filename;
document.body.appendChild(a); a.click();
document.body.removeChild(a);
setTimeout(() => URL.revokeObjectURL(url), 1000);
});

return block;
}

