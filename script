function buildCodeBlock(lang, filename, rawCode) {
const tpl    = document.getElementById(‘codeBlockTpl’).content.cloneNode(true);
const block  = tpl.querySelector(’.code-block’);
const badge  = tpl.querySelector(’.code-lang-badge’);
const fnEl   = tpl.querySelector(’.code-filename’);
const codeEl = tpl.querySelector(‘code’);
const copyBtn= tpl.querySelector(’.copy-btn’);
const dlBtn  = tpl.querySelector(’.dl-btn’);

badge.textContent     = lang.toUpperCase();
fnEl.textContent      = filename || ‘’;
codeEl.innerHTML      = highlight(rawCode, lang);

// Copy
copyBtn.addEventListener(‘click’, () => {
navigator.clipboard.writeText(rawCode).then(() => {
copyBtn.textContent = ‘✅ تم النسخ’;
copyBtn.classList.add(‘copied’);
setTimeout(() => {
copyBtn.textContent = ‘📋 نسخ’;
copyBtn.classList.remove(‘copied’);
}, 2000);
});
});

// Download single file
dlBtn.addEventListener(‘click’, () => {
const blob = new Blob([rawCode], { type: ‘text/plain;charset=utf-8’ });
const a    = document.createElement(‘a’);
a.href     = URL.createObjectURL(blob);
a.download = filename || `code.${lang}`;
a.click();
});

return block;
}

/* ═══════════════════════════════════════════
PARSE AI RESPONSE → files array
═══════════════════════════════════════════ */
function parseFiles(text) {
const files = [];
// Matches `lang:filename ... ` OR `lang ... `
const re = /`([\w#+.\-]+)(?::([^\n]+))?\n([\s\S]*?)`/g;
let m;
while ((m = re.exec(text)) !== null) {
const lang     = m[1].toLowerCase().replace(/^(html|css|js|javascript|python|py|ts|typescript|jsx|tsx|vue|php|java|cpp|c|cs|csharp|go|rust|dart|kotlin|swift|sql|yaml|json|xml|md|bash|sh|ruby|rb)$/i, ‘$1’);
const filename = (m[2] || ‘’).trim() || guessFilename(lang, files.length);
const code     = m[3];
files.push({ lang, filename, code });
}
return files;
}

function guessFilename(lang, idx) {
const map = {
html: ‘index.html’, css: ‘style.css’,
javascript: ‘script.js’, js: ‘script.js’,
typescript: ‘app.ts’, ts: ‘app.ts’,
python: ‘main.py’, py: ‘main.py’,
java: ‘Main.java’, cpp: ‘main.cpp’,
csharp: ‘Program.cs’, cs: ‘Program.cs’,
dart: ‘main.dart’, vue: ‘App.vue’,
php: ‘index.php’, go: ‘main.go’,
rust: ‘main.rs’, ruby: ‘main.rb’,
sql: ‘schema.sql’, json: ‘data.json’,
yaml: ‘config.yaml’, bash: ‘run.sh’, sh: ‘run.sh’,
};
return map[lang] || `file_${idx + 1}.${lang}`;
}

