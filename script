els.welcomeScreen.style.display = ‘’;
});

els.toggleSidebar.addEventListener(‘click’, () => els.sidebar.classList.toggle(‘collapsed’));
els.openSidebar.addEventListener(‘click’,   () => els.sidebar.classList.remove(‘collapsed’));

els.themeToggle.addEventListener(‘change’, e => applyTheme(e.target.checked));

// ZIP modal buttons
els.zipDownloadBtn.addEventListener(‘click’, downloadZip);
els.zipCancelBtn.addEventListener(‘click’, closeZipModal);
els.zipModal.addEventListener(‘click’, e => { if (e.target === els.zipModal) closeZipModal(); });

