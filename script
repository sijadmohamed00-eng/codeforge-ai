function openZipModal(files) {
state.pendingFiles = files;
els.zipModalDesc.textContent = `${files.length} ملف/ملفات جاهزة للتحميل`;
els.zipFilesList.innerHTML   = ‘’;

files.forEach(f => {
const item = document.createElement(‘div’);
item.className = ‘modal-file-item’;
item.innerHTML = `<span>📄</span> ${escapeHtml(f.filename)} <span style="color:var(--text3);margin-right:auto">${f.lang.toUpperCase()}</span>`;
els.zipFilesList.appendChild(item);
});

els.zipModal.removeAttribute(‘hidden’);
}

async function downloadZip() {
const files = state.pendingFiles;
if (!files.length) return;

const zip = new JSZip();
files.forEach(f => zip.file(f.filename, f.code));

const blob = await zip.generateAsync({ type: ‘blob’ });
const url  = URL.createObjectURL(blob);
const a    = document.createElement(‘a’);
a.href     = url;
a.download = ‘codeforge-project.zip’;
a.click();
URL.revokeObjectURL(url);

els.zipModal.setAttribute(‘hidden’, ‘’);
}

