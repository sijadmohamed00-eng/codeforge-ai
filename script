function getActiveConv() {
return state.conversations.find(c => c.id === state.activeId);
}

function newConversation(firstMsg) {
const id    = Date.now().toString();
const title = firstMsg.slice(0, 42) + (firstMsg.length > 42 ? ‘…’ : ‘’);
const conv  = { id, title, messages: [] };
state.conversations.unshift(conv);
state.activeId = id;
renderHistoryList();
return conv;
}

function renderHistoryList() {
els.historyList.innerHTML = ‘’;
state.conversations.forEach(conv => {
const li = document.createElement(‘li’);
li.className   = ‘history-item’ + (conv.id === state.activeId ? ’ active’ : ‘’);
li.textContent = conv.title;
li.addEventListener(‘click’, () => switchConversation(conv.id));
els.historyList.appendChild(li);
});
}

function switchConversation(id) {
state.activeId = id;
renderHistoryList();
const conv = getActiveConv();
els.topbarTitle.textContent = conv ? conv.title : ‘مساعد الكودنك الذكي’;
els.messagesList.innerHTML = ‘’;
els.welcomeScreen.style.display = ‘none’;
if (conv) {
conv.messages.forEach(m => {
if (m.role === ‘user’) {
els.messagesList.appendChild(renderUserMessage(m.content));
} else {
els.messagesList.appendChild(renderAIMessage(m.content));
}
});
}
scrollBottom();
}

