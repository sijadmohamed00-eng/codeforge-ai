INIT
══════════════════════════════════ */
(function init() {
// Theme
let savedTheme;
try { savedTheme = localStorage.getItem(‘cf_theme’); } catch(e) {}
const light = savedTheme === ‘light’;
els.themeToggle.checked = light;
applyTheme(light);

// Check saved API key
let savedKey;
try { savedKey = localStorage.getItem(‘cf_apikey’); } catch(e) {}

if (savedKey && savedKey.startsWith(‘sk-ant-’)) {
state.apiKey = savedKey;
showApp();
} else {
showApiKeyScreen();
}
})();
