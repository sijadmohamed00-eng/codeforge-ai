function openZipModal(files) {
if (!files || !files.length) return;

state.pendingFiles = files;
els.zipModalDesc.textContent = `${files.length} ملف جاهز للتحميل`;
els.zipFilesList.innerHTML = ‘’;

files.forEach(f => {
const item = document.createElement(‘div’);
item.className = ‘modal-file-item’;
item.innerHTML = `<span class="fi-icon">📄</span> ${escHtml(f.filename)} <span style="color:var(--text3);margin-right:auto">${(f.lang||'').toUpperCase()}</span>`;
els.zipFilesList.appendChild(item);
});

els.zipModal.style.display = ‘flex’;
}

function closeZipModal() {
els.zipModal.style.display = ‘none’;
}

async function downloadZip() {
const files = state.pendingFiles;
if (!files || !files.length) return;

els.zipDownloadBtn.textContent = ‘⏳ جاري التجميع…’;
els.zipDownloadBtn.disabled = true;

try {
if (typeof JSZip === ‘undefined’) throw new Error(‘مكتبة JSZip غير محمّلة’);
const zip = new JSZip();
files.forEach(f => zip.file(f.filename || `file.${f.lang||'txt'}`, f.code || ‘’));
const blob = await zip.generateAsync({ type: ‘blob’ });
const url  = URL.createObjectURL(blob);
const a    = document.createElement(‘a’);
a.href = url; a.download = ‘codeforge-project.zip’;
document.body.appendChild(a); a.click(); document.body.removeChild(a);
setTimeout(() => URL.revokeObjectURL(url), 2000);
closeZipModal();
} catch (err) {
alert(’فشل التحميل: ’ + err.message);
} finally {
els.zipDownloadBtn.textContent = ‘⬇ تحميل ZIP’;
els.zipDownloadBtn.disabled = false;
}
}

