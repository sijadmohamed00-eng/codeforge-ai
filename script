/* ══════════════════════════════════
SYNTAX HIGHLIGHTER
══════════════════════════════════ */
function highlight(code, lang) {
let c = code.replace(/&/g,’&’).replace(/</g,’<’).replace(/>/g,’>’);

if ([‘html’,‘xml’].includes(lang)) {
c = c
.replace(/(</?)([\w-]+)/g, ‘$1<span class="t-tag">$2</span>’)
.replace(/([\w:-]+)=/g, ‘<span class="t-attr">$1</span>=’)
.replace(/(”.*?”|’.*?’)/g, ‘<span class="t-str">$1</span>’)
.replace(/(//.*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(<!–[\s\S]*?–>)/g, ‘<span class="t-cm">$1</span>’);
} else if ([‘css’,‘scss’].includes(lang)) {
c = c
.replace(/(/*[\s\S]*?*/)/g, ‘<span class="t-cm">$1</span>’)
.replace(/([\w-]+)\s*:/g, ‘<span class="t-attr">$1</span>:’)
.replace(/:\s*([^;{}]+)/g, (m,v) => ‘: <span class="t-str">’+v+’</span>’)
.replace(/(\d+(?:.\d+)?(?:px|em|rem|%|vh|vw|s|ms|deg))/g, ‘<span class="t-num">$1</span>’);
} else if ([‘js’,‘javascript’,‘ts’,‘typescript’,‘jsx’,‘tsx’].includes(lang)) {
c = c
.replace(/(//[^\n]*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(/*[\s\S]*?*/)/g, ‘<span class="t-cm">$1</span>’)
.replace(/\b(const|let|var|function|class|return|if|else|for|while|do|switch|case|break|continue|import|export|default|async|await|try|catch|finally|new|this|typeof|instanceof|of|in|from|extends|super|static|true|false|null|undefined|void|delete|throw|yield)\b/g, ‘<span class="t-kw">$1</span>’)
.replace(/\b([a-zA-Z_$][\w$]*)\s*(/g, ‘<span class="t-fn">$1</span>(’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’|`(?:[^`\]|\.)*`)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
} else if ([‘python’,‘py’].includes(lang)) {
c = c
.replace(/(#[^\n]*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(”””[\s\S]*?”””|'''[\s\S]*?''')/g, ‘<span class="t-cm">$1</span>’)
.replace(/\b(def|class|return|if|elif|else|for|while|import|from|as|with|try|except|finally|raise|pass|break|continue|lambda|yield|global|nonlocal|and|or|not|in|is|True|False|None|async|await|print)\b/g, ‘<span class="t-kw">$1</span>’)
.replace(/\b([a-zA-Z_]\w*)\s*(/g, ‘<span class="t-fn">$1</span>(’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
} else {
c = c
.replace(/(//[^\n]*|#[^\n]*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
}
return c;
}

/* ══════════════════════════════════
PARSE FILES FROM AI RESPONSE
══════════════════════════════════ */
function parseFiles(text) {
const files = [];
const re = /`([\w#+.\-]+)(?::([^\n`]+))?\n([\s\S]*?)`/g;
let m;
while ((m = re.exec(text)) !== null) {
const lang     = m[1].toLowerCase();
const filename = (m[2] || ‘’).trim() || autoFilename(lang, files.length);
const code     = m[3];
if (code.trim()) files.push({ lang, filename, code });
}
return files;
}

function autoFilename(lang, idx) {
const map = {
html:‘index.html’, css:‘style.css’, javascript:‘script.js’, js:‘script.js’,
typescript:‘app.ts’, ts:‘app.ts’, jsx:‘App.jsx’, tsx:‘App.tsx’,
python:‘main.py’, py:‘main.py’, java:‘Main.java’, cpp:‘main.cpp’,
c:‘main.c’, csharp:‘Program.cs’, cs:‘Program.cs’, dart:‘main.dart’,
vue:‘App.vue’, php:‘index.php’, go:‘main.go’, rust:‘main.rs’,
ruby:‘main.rb’, sql:‘schema.sql’, json:‘data.json’, yaml:‘config.yaml’,
bash:‘run.sh’, sh:‘run.sh’, kotlin:‘Main.kt’, swift:‘main.swift’,
};
return map[lang] || `file_${idx+1}.${lang}`;
}

function stripCodeBlocks(text) {
return text.replace(/`[\s\S]*?`/g, ‘’).replace(/\n{3,}/g, ‘\n\n’).trim();
}

