/* ═══════════════════════════════════════════
SYNTAX HIGHLIGHTER (client-side, regex)
═══════════════════════════════════════════ */
function highlight(code, lang) {
// Escape HTML first
let c = code
.replace(/&/g, ‘&’)
.replace(/</g, ‘<’)
.replace(/>/g, ‘>’);

if ([‘html’, ‘xml’].includes(lang)) {
c = c
.replace(/(</?)([\w-]+)/g, ‘$1<span class="t-tag">$2</span>’)
.replace(/([\w-]+)(=)/g, ‘<span class="t-attr">$1</span>$2’)
.replace(/(”.*?”)/g, ‘<span class="t-str">$1</span>’)
.replace(/(//.*)/g, ‘<span class="t-cm">$1</span>’);
} else if (lang === ‘css’ || lang === ‘scss’) {
c = c
.replace(/(/*[\s\S]*?*/)/g, ‘<span class="t-cm">$1</span>’)
.replace(/([.#][\w-]+(?:\s*,\s*[.#][\w-]+)*)\s*{/g, ‘<span class="t-sel">$1</span> {’)
.replace(/([\w-]+)\s*:/g, ‘<span class="t-attr">$1</span>:’)
.replace(/:\s*([^;{}]+)/g, ‘: <span class="t-str">$1</span>’)
.replace(/(\d+(?:.\d+)?(?:px|em|rem|%|vh|vw|s|ms))/g, ‘<span class="t-num">$1</span>’);
} else if ([‘js’, ‘javascript’, ‘ts’, ‘typescript’].includes(lang)) {
c = c
.replace(/(//.*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(/*[\s\S]*?*/)/g, ‘<span class="t-cm">$1</span>’)
.replace(/\b(const|let|var|function|class|return|if|else|for|while|do|switch|case|break|continue|import|export|default|async|await|try|catch|finally|new|this|typeof|instanceof|of|in|from|extends|super|static|get|set|yield|void|delete|throw)\b/g, ‘<span class="t-kw">$1</span>’)
.replace(/\b([A-Z][a-zA-Z0-9_]*)\b/g, ‘<span class="t-cls">$1</span>’)
.replace(/\b([a-zA-Z_$][a-zA-Z0-9_$]*)\s*(/g, ‘<span class="t-fn">$1</span>(’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’|`(?:[^`\]|\.)*`)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
} else if ([‘python’, ‘py’].includes(lang)) {
c = c
.replace(/(#.*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(”””[\s\S]*?”””|’’’[\s\S]*?’’’)/g, ‘<span class="t-cm">$1</span>’)
.replace(/\b(def|class|return|if|elif|else|for|while|import|from|as|with|try|except|finally|raise|pass|break|continue|lambda|yield|global|nonlocal|and|or|not|in|is|True|False|None|async|await)\b/g, ‘<span class="t-kw">$1</span>’)
.replace(/\b([A-Z][a-zA-Z0-9_]*)\b/g, ‘<span class="t-cls">$1</span>’)
.replace(/\b([a-zA-Z_][a-zA-Z0-9_]*)\s*(/g, ‘<span class="t-fn">$1</span>(’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
} else {
// Generic — just strings and comments
c = c
.replace(/(//.*|#.*)/g, ‘<span class="t-cm">$1</span>’)
.replace(/(”(?:[^”\]|\.)*”|’(?:[^’\]|\.)*’)/g, ‘<span class="t-str">$1</span>’)
.replace(/\b(\d+(?:.\d+)?)\b/g, ‘<span class="t-num">$1</span>’);
}

return c;
}

