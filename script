function setState(loading) {
State.isLoading = loading;
const btn = document.getElementById(‘send-btn’);
const icon = document.getElementById(‘send-icon’);
const textarea = document.getElementById(‘user-input’);
if (btn) {
btn.disabled = loading;
btn.classList.toggle(‘loading’, loading);
}
if (icon) icon.textContent = loading ? ‘⏳’ : ‘⚡’;
if (textarea) textarea.disabled = loading;
}

function scrollToBottom() {
const area = document.getElementById(‘messages-area’);
if (area) setTimeout(() => { area.scrollTop = area.scrollHeight; }, 50);
}

function copyToClipboard(text) {
navigator.clipboard.writeText(text).catch(() => {
// Fallback
const ta = document.createElement(‘textarea’);
ta.value = text;
ta.style.position = ‘fixed’;
ta.style.opacity = ‘0’;
document.body.appendChild(ta);
ta.select();
document.execCommand(‘copy’);
document.body.removeChild(ta);
});
}

function escapeHtml(str) {
return String(str)
.replace(/&/g, ‘&’)
.replace(/</g, ‘<’)
.replace(/>/g, ‘>’)
.replace(/”/g, ‘"’)
.replace(/’/g, ‘'’);
}

function sanitizeFilename(str) {
return str.replace(/[^a-zA-Z0-9\u0600-\u06FF *-]/g, ’*’).replace(/\s+/g, ‘_’);
}

function delay(ms) {
return new Promise(r => setTimeout(r, ms));
}

let _toastTimer = null;
function showToast(msg) {
const toast = document.getElementById(‘toast’);
toast.textContent = msg;
toast.classList.remove(‘hidden’);
clearTimeout(_toastTimer);
_toastTimer = setTimeout(() => toast.classList.add(‘hidden’), 3000);
}

// ───────────────────────── KEYBOARD SHORTCUTS ────────────────────
document.addEventListener(‘keydown’, (e) => {
// Escape: close modal
if (e.key === ‘Escape’) closeModal();
// ?: show shortcuts hint
if (e.key === ‘?’ && !e.target.closest(‘input, textarea’)) {
showToast(‘⌨️ Ctrl+Enter: إرسال | Esc: إغلاق’);
}
});
